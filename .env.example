# Oracle Forge — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# ── LLM ─────────────────────────────────────────────────────────────────────
OPEN_ROUTER_KEY=sk-or-v1-...

# ── PostgreSQL (primary — Yelp) ───────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=yelp
POSTGRES_USER=oracle_forge
POSTGRES_PASSWORD=your_password_here

# ── PostgreSQL (additional datasets) ─────────────────────────────────────────
BOOKREVIEW_POSTGRES_DB=bookreview_db
CRM_SUPPORT_POSTGRES_DB=crm_support
PANCANCER_POSTGRES_DB=pancancer_clinical
GOOGLELOCAL_POSTGRES_DB=googlelocal_db
PATENT_CPC_POSTGRES_DB=patent_CPCDefinition
# PATENTS publication SQLite (~5GB if full) — after load: db/patent_publication.db
PATENT_PUBLICATION_SQLITE_PATH=db/patent_publication.db
# Optional: override source when copying in load_datasets_from_dab.sh
# PATENT_PUBLICATION_SOURCE=/path/to/patent_publication.db

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=

# ── File-based databases ─────────────────────────────────────────────────────
SQLITE_PATH=db/dab_sqlite.db
DUCKDB_PATH=db/yelp_user.db

# ── File-based datasets (SQLite + DuckDB) — paths under repo after load script ─
# Load all file DBs + optional PostgreSQL/Mongo from DataAgentBench:
#   bash scripts/load_datasets_from_dab.sh
# File copies only (no psql/mongorestore):
#   FILES_ONLY=1 bash scripts/load_datasets_from_dab.sh
DEPS_DEV_SQLITE_PATH=db/deps_dev_package_query.db
DEPS_DEV_DUCKDB_PATH=db/deps_dev_project_query.db
MUSIC_BRAINZ_TRACKS_PATH=db/music_brainz_tracks.db
MUSIC_BRAINZ_SALES_PATH=db/music_brainz_sales.duckdb

# ── DataAgentBench root ───────────────────────────────────────────────────────
DAB_ROOT=/home/ubuntu/shared/DataAgentBench

# GITHUB_REPOS (SQLite metadata + DuckDB artifacts)
GITHUB_REPOS_METADATA_PATH=db/github_repos_metadata.db
GITHUB_REPOS_ARTIFACTS_PATH=db/github_repos_artifacts.db
